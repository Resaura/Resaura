{
  "cli": { "appVersionSource": "remote" },
  "build": {
    "preview-android": {
      "channel": "preview",
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production-android": {
      "channel": "production",
      "distribution": "store",
      "android": { "buildType": "apk" },
      "autoIncrement": true
    },
    "preview-ios": {
      "channel": "preview",
      "distribution": "internal"
    },
    "production-ios": {
      "channel": "production",
      "distribution": "store",
      "autoIncrement": true
    }
  },
  "submit": {
    "production-android": { "android": { "track": "production" } },
    "production-ios": {}
  }
}

